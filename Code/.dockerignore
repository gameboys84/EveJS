# The runtime image only needs these application trees. Keeping the context
# explicit prevents large local caches, logs, generated data, and test stores
# from being sent to the Linux Docker builder.
**
!Dockerfile
!evejs.config.local.json
!server/
!server/**
!tools/
!tools/DatabaseCreator/
!tools/DatabaseCreator/**
!tools/market-seed/
!tools/market-seed/**
!tools/market-seederv2/
!tools/market-seederv2/**
!externalservices/
!externalservices/market-server/
!externalservices/market-server/**
!docker/
!docker/**

**/node_modules
**/node_modules/**
**/target
**/target/**
server/logs
server/logs/**
server/tests
server/tests/**
server/src/logs
server/src/logs/**
server/src/_secondary/data/chat
server/src/_secondary/data/chat/**
server/src/_secondary/image/generated/Character
server/src/_secondary/image/generated/Character/**
server/src/gameStore/data/*/data.json
**/*.sqlite*
**/.env
**/.env.*
server/certs/**
!server/certs/.gitkeep
server/src/_secondary/express/certs/*.pem
server/src/_secondary/express/certs/*.pfx
server/src/_secondary/express/certs/*.key
server/src/_secondary/express/certs/*passphrase*.txt
externalservices/market-server/data/generated
externalservices/market-server/data/generated/**
tools/market-seederv2/cache
tools/market-seederv2/cache/**
